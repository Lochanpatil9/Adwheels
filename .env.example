VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Razorpay — get from https://dashboard.razorpay.com/app/keys
VITE_RAZORPAY_KEY_ID=rzp_test_your-key-id-here

# WhatsApp notifications — set these as Supabase Edge Function secrets, NOT here
# See supabase/functions/send-whatsapp/index.ts for full instructions
# WHATSAPP_PROVIDER=msg91          # or: twilio
# MSG91_API_KEY=your-msg91-key
# MSG91_TEMPLATE_ID=your-template-id
# TWILIO_ACCOUNT_SID=ACxxx
# TWILIO_AUTH_TOKEN=your-token
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
